        <mxCell id="N0t3ncGl6tLSLLua91So-236" parent="1" style="text;whiteSpace=wrap;html=1;" value="&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;b&gt;Direct Write + Redis Cache + Sharded DB : For management of Likes and Comments&lt;/b&gt;&lt;/font&gt;" vertex="1">
