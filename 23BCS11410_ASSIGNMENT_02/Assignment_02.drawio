        </mxCell>
        <mxCell id="N0t3ncGl6tLSLLua91So-238" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot; face=&quot;Times New Roman&quot;&gt;Functional Requirements :&amp;nbsp;&lt;/font&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font face=&quot;Times New Roman&quot; style=&quot;font-size: 18px;&quot;&gt;Users should be able to &lt;strong data-start=&quot;438&quot; data-end=&quot;461&quot; style=&quot;&quot;&gt;register and log in&lt;/strong&gt; to the platform&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font size=&quot;3&quot; face=&quot;Times New Roman&quot;&gt;Users should be able to &lt;strong data-start=&quot;652&quot; data-end=&quot;669&quot;&gt;upload videos&lt;/strong&gt; with metadata&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font size=&quot;3&quot; face=&quot;Times New Roman&quot;&gt;Users should be able to &lt;strong data-start=&quot;1290&quot; data-end=&quot;1319&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;watch videos in real time&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font size=&quot;3&quot; face=&quot;Times New Roman&quot;&gt;The system should support &lt;strong data-start=&quot;1349&quot; data-end=&quot;1379&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;adaptive bitrate streaming&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;.&lt;/span&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font size=&quot;3&quot;&gt;&lt;font face=&quot;Times New Roman&quot;&gt;Users Should be able to like and comments&lt;/font&gt;&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font size=&quot;3&quot;&gt;The system should provide &lt;strong data-start=&quot;2257&quot; data-end=&quot;2280&quot;&gt;fast search results&lt;/strong&gt; using a search engine (e.g., Elasticsearch)&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="180" width="748.76" x="12.489999999999998" y="-610" as="geometry" />
        </mxCell>
        <mxCell id="N0t3ncGl6tLSLLua91So-239" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;font style=&quot;font-size: 18px;&quot; face=&quot;Times New Roman&quot;&gt;Non -Functional Requirements:&lt;/font&gt;&lt;div&gt;&lt;font style=&quot;&quot; face=&quot;Times New Roman&quot; size=&quot;3&quot;&gt;&lt;ul data-start=&quot;3087&quot; data-end=&quot;3189&quot; style=&quot;&quot;&gt;&lt;li data-section-id=&quot;yh9i2q&quot; data-start=&quot;3087&quot; data-end=&quot;3142&quot; style=&quot;&quot;&gt;&lt;h3 data-section-id=&quot;1f1f7c7&quot; data-start=&quot;3068&quot; data-end=&quot;3086&quot;&gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;Video playback should start within &lt;/span&gt;&lt;strong data-start=&quot;3124&quot; data-end=&quot;3141&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;a few seconds&lt;/strong&gt;&lt;/h3&gt;&lt;/li&gt;&lt;li data-section-id=&quot;yh9i2q&quot; data-start=&quot;3087&quot; data-end=&quot;3142&quot; style=&quot;&quot;&gt;&lt;h3 data-section-id=&quot;1f1f7c7&quot; data-start=&quot;3068&quot; data-end=&quot;3086&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;High Availability :&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;The platform should be available &lt;/span&gt;&lt;strong data-start=&quot;2923&quot; data-end=&quot;2953&quot; style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;24/7 with minimal downtime&lt;/strong&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;.&lt;/span&gt;&lt;/h3&gt;&lt;/li&gt;&lt;li data-section-id=&quot;yh9i2q&quot; data-start=&quot;3087&quot; data-end=&quot;3142&quot; style=&quot;&quot;&gt;&lt;div style=&quot;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255)); font-weight: normal;&quot;&gt;The system must support &lt;strong data-start=&quot;2738&quot; data-end=&quot;2770&quot; style=&quot;&quot;&gt;millions of concurrent users&lt;/strong&gt;.&lt;/span&gt;&lt;/div&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/font&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="130" width="766.27" x="12.490000000000027" y="-290" as="geometry" />
        </mxCell>
