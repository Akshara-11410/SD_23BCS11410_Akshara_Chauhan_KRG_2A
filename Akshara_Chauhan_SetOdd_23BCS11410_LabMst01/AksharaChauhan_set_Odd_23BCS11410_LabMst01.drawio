<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.1 Chrome/142.0.7444.265 Electron/39.8.0 Safari/537.36" version="29.6.1">
  <diagram name="Page-1" id="HJJwETbPCcyrsnuSetww">
    <mxGraphModel dx="1747" dy="1302" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="7RN8qIJpGZDpxKWlOK2p-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="Design an Instagram like system wuth following :&lt;div&gt;User Login service&amp;nbsp;&lt;/div&gt;&lt;div&gt;Content Service&amp;nbsp;&lt;/div&gt;&lt;div&gt;Feed Service&amp;nbsp;&lt;/div&gt;&lt;div&gt;Follower Service&amp;nbsp;&lt;/div&gt;&lt;div&gt;User Engagement service&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;Implement a mechanism to restrict the user for posting a non-policy compliant post&amp;nbsp;&lt;/li&gt;&lt;li&gt;optimize the dynamic feed genration for the users&amp;nbsp;&lt;/li&gt;&lt;li&gt;highlight the use of BackFill service&amp;nbsp;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="200" width="360" x="10" y="40" as="geometry" />
        </mxCell>
        <mxCell id="7RN8qIJpGZDpxKWlOK2p-2" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Functional Requirements :&lt;/b&gt;&lt;div&gt;1. User should be able to login/register him/her on the system&amp;nbsp;&lt;/div&gt;&lt;div&gt;2.User should able to follow other people on System&amp;nbsp;&lt;/div&gt;&lt;div&gt;3. User should be able to see the latest feed of the following people .&lt;/div&gt;&lt;div&gt;4. User should be able to like/comment on the other users post&amp;nbsp;&lt;/div&gt;&lt;div&gt;5.User should be able to create a post and post it&amp;nbsp; on system&amp;nbsp;&lt;/div&gt;&lt;div&gt;6. The policy must be adhered for the post , user has posted.&amp;nbsp;&lt;/div&gt;" vertex="1">
          <mxGeometry height="90" width="400" x="20" y="280" as="geometry" />
        </mxCell>
        <mxCell id="7RN8qIJpGZDpxKWlOK2p-3" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Non - Functional Requirements:&lt;/b&gt;&lt;div&gt;1.Latency must be low&amp;nbsp;&lt;/div&gt;&lt;div&gt;2.Availability &amp;gt;&amp;gt;&amp;gt; Consistency (Users must be able to see the post of other people .&lt;/div&gt;&lt;div&gt;3.System must be compatible with heavy audience interaction(1.5 Billion users)&lt;b&gt;&amp;nbsp;&lt;/b&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="60" width="380" x="40" y="450" as="geometry" />
        </mxCell>
        <mxCell id="7RN8qIJpGZDpxKWlOK2p-4" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;" value="&lt;b&gt;Entities :&lt;/b&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;User&amp;nbsp;&lt;/li&gt;&lt;li&gt;Post&amp;nbsp;&lt;/li&gt;&lt;li&gt;Follower&amp;nbsp;&lt;/li&gt;&lt;li&gt;Like/Comment&lt;b&gt;&amp;nbsp;&lt;/b&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="30" width="150" x="110" y="620" as="geometry" />
